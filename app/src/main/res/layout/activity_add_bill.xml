<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header Card with room number -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="#2196F3"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <TextView
                android:id="@+id/tvRoomNumber"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="20dp"
                android:text="102"
                android:textColor="#000000"
                android:textSize="24sp"
                android:textStyle="bold" />
        </androidx.cardview.widget.CardView>

        <!-- Main Content Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Date -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ngày"
                    android:textColor="#000000"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="16dp"
                    app:endIconDrawable="@android:drawable/ic_menu_my_calendar"
                    app:endIconMode="custom">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etDate"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:focusable="false"
                        android:hint="09/11/2025"
                        android:inputType="none" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Old electric/water info -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Thông tin điện nước cũ"
                    android:textColor="#000000"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingEnd="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Số điện cũ"
                            android:textColor="#000000"
                            android:textSize="14sp" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etOldElectric"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="0"
                                android:inputType="number" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingStart="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Số nước cũ"
                            android:textColor="#000000"
                            android:textSize="14sp" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etOldWater"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="0"
                                android:inputType="number" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- Old electric/water images -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingEnd="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Hình điện cũ"
                            android:textColor="#000000"
                            android:textSize="14sp" />

                        <FrameLayout
                            android:id="@+id/flOldElectricImage"
                            android:layout_width="match_parent"
                            android:layout_height="120dp"
                            android:layout_marginTop="8dp"
                            android:background="#E8E8E8">

                            <ImageView
                                android:id="@+id/ivOldElectric"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="centerCrop" />

                            <ImageButton
                                android:id="@+id/btnAddOldElectricImage"
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:layout_gravity="center"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:src="@android:drawable/ic_menu_camera"
                                app:tint="#999999" />
                        </FrameLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingStart="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Hình nước cũ"
                            android:textColor="#000000"
                            android:textSize="14sp" />

                        <FrameLayout
                            android:id="@+id/flOldWaterImage"
                            android:layout_width="match_parent"
                            android:layout_height="120dp"
                            android:layout_marginTop="8dp"
                            android:background="#E8E8E8">

                            <ImageView
                                android:id="@+id/ivOldWater"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="centerCrop" />

                            <ImageButton
                                android:id="@+id/btnAddOldWaterImage"
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:layout_gravity="center"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:src="@android:drawable/ic_menu_camera"
                                app:tint="#999999" />
                        </FrameLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- New electric/water info -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="Thông tin điện nước mới"
                    android:textColor="#000000"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingEnd="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Số điện mới"
                            android:textColor="#000000"
                            android:textSize="14sp" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etNewElectric"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="0"
                                android:inputType="number" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingStart="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Số nước mới"
                            android:textColor="#000000"
                            android:textSize="14sp" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etNewWater"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="0"
                                android:inputType="number" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- New electric/water images -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingEnd="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Hình điện mới"
                            android:textColor="#000000"
                            android:textSize="14sp" />

                        <FrameLayout
                            android:id="@+id/flNewElectricImage"
                            android:layout_width="match_parent"
                            android:layout_height="120dp"
                            android:layout_marginTop="8dp"
                            android:background="#E8E8E8">

                            <ImageView
                                android:id="@+id/ivNewElectric"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="centerCrop" />

                            <ImageButton
                                android:id="@+id/btnAddNewElectricImage"
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:layout_gravity="center"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:src="@android:drawable/ic_menu_camera"
                                app:tint="#999999" />
                        </FrameLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingStart="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Hình nước mới"
                            android:textColor="#000000"
                            android:textSize="14sp" />

                        <FrameLayout
                            android:id="@+id/flNewWaterImage"
                            android:layout_width="match_parent"
                            android:layout_height="120dp"
                            android:layout_marginTop="8dp"
                            android:background="#E8E8E8">

                            <ImageView
                                android:id="@+id/ivNewWater"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="centerCrop" />

                            <ImageButton
                                android:id="@+id/btnAddNewWaterImage"
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:layout_gravity="center"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:src="@android:drawable/ic_menu_camera"
                                app:tint="#999999" />
                        </FrameLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- Dịch vụ thêm -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="Dịch vụ thêm"
                    android:textColor="#000000"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <!-- Tiền phòng -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Tiền phòng"
                    android:textColor="#000000"
                    android:textSize="14sp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etRoomPrice"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="5,000,000"
                        android:inputType="number" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Tiền Internet -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Tiền Internet"
                    android:textColor="#000000"
                    android:textSize="14sp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etInternetPrice"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="100,000"
                        android:inputType="number" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Ghi chú -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Ghi chú"
                    android:textColor="#000000"
                    android:textSize="14sp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etNote"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Ví dụ tháng trước còn thiếu 20,000"
                        android:inputType="textMultiLine"
                        android:minLines="2" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Bảng tính toán -->
                <TableLayout
                    android:id="@+id/calculationTable"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp">

                    <!-- Header -->
                    <TableRow
                        android:background="#E0E0E0"
                        android:padding="8dp">

                        <TextView
                            android:layout_weight="1"
                            android:text="Dịch vụ"
                            android:textStyle="bold" />

                        <TextView
                            android:gravity="center"
                            android:minWidth="50dp"
                            android:text="Số"
                            android:textStyle="bold" />

                        <TextView
                            android:gravity="end"
                            android:minWidth="80dp"
                            android:text="Giá"
                            android:textStyle="bold" />

                        <TextView
                            android:gravity="end"
                            android:minWidth="90dp"
                            android:text="Tiền"
                            android:textStyle="bold" />
                    </TableRow>

                    <!-- Tiền điện -->
                    <TableRow android:padding="8dp">

                        <TextView
                            android:layout_weight="1"
                            android:text="Tiền điện" />

                        <TextView
                            android:id="@+id/tvElectricQuantity"
                            android:gravity="center"
                            tools:text="0" />

                        <TextView
                            android:id="@+id/tvElectricUnitPrice"
                            android:gravity="end"
                            tools:text="4,000" />

                        <TextView
                            android:id="@+id/tvElectricTotal"
                            android:gravity="end"
                            tools:text="0" />
                    </TableRow>

                    <!-- Tiền nước -->
                    <TableRow android:padding="8dp">

                        <TextView
                            android:layout_weight="1"
                            android:text="Tiền nước" />

                        <TextView
                            android:id="@+id/tvWaterQuantity"
                            android:gravity="center"
                            tools:text="0" />

                        <TextView
                            android:id="@+id/tvWaterUnitPrice"
                            android:gravity="end"
                            tools:text="20,000" />

                        <TextView
                            android:id="@+id/tvWaterTotal"
                            android:gravity="end"
                            tools:text="0" />
                    </TableRow>

                    <!-- Tiền phòng -->
                    <TableRow android:padding="8dp">

                        <TextView
                            android:layout_weight="1"
                            android:text="Tiền phòng" />

                        <TextView
                            android:gravity="center"
                            android:text="1" />

                        <TextView
                            android:id="@+id/tvRoomUnitPrice"
                            android:gravity="end"
                            tools:text="3,000,000" />

                        <TextView
                            android:id="@+id/tvRoomTotal"
                            android:gravity="end"
                            tools:text="3,000,000" />
                    </TableRow>

                    <!-- Tiền Internet -->
                    <TableRow android:padding="8dp">

                        <TextView
                            android:layout_weight="1"
                            android:text="Tiền Internet" />

                        <TextView
                            android:gravity="center"
                            android:text="1" />

                        <TextView
                            android:id="@+id/tvInternetUnitPrice"
                            android:gravity="end"
                            tools:text="100,000" />

                        <TextView
                            android:id="@+id/tvInternetTotal"
                            android:gravity="end"
                            tools:text="100,000" />
                    </TableRow>

                    <!-- Divider -->
                    <View
                        android:layout_height="1dp"
                        android:background="#E0E0E0" />

                    <!-- Tổng tiền -->
                    <TableRow android:padding="8dp">

                        <TextView
                            android:layout_span="3"
                            android:text="Tổng tiền"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvGrandTotal"
                            android:gravity="end"
                            android:textStyle="bold"
                            tools:text="3,600,000" />
                    </TableRow>

                </TableLayout>

                <!-- Nút Duyệt hóa đơn -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnApproveInvoice"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="24dp"
                    app:backgroundTint="#03A9F4"
                    android:text="Tạo hóa đơn"
                    app:cornerRadius="8dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>
</ScrollView>